# 应用配置
APP_ENV=development
APP_NAME="Dynamic Literature Matrix"
LOG_LEVEL=INFO

# CORS配置
CORS_ORIGINS=http://localhost:3000

# Mock配置
USE_MOCK_SEARCH=true
USE_MOCK_EXTRACTION=true

